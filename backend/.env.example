# AI reasoning via OpenRouter. Provision the key with:
#   npx @insforge/cli ai setup --env-file backend/.env
# Set OPENROUTER_MODEL to any OpenRouter model id (e.g. openai/gpt-4o-mini).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# Path to a kubeconfig for cluster investigation (optional)
KUBECONFIG_PATH=

# Comma-separated list of allowed CORS origins for the frontend
CORS_ORIGINS=http://localhost:3000
